rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins collection: only admins can read/write, or self-read for login checks
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Bookings collection: anyone can create (write new booking), only admins can read, update, delete
    match /bookings/{bookingId} {
      allow create, read: if true;
  allow update, delete: if isAdmin();
}

    // Services, Employees, Testimonials, Gallery, Settings: anyone can read, only admins can write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
